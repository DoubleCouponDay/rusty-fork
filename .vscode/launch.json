{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [


        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug codelldb empty project",
            "cargo": {
                "args": [
                    "build",
                    "--bin=plc",
                    "--package=plc_driver"
                ],
                "filter": {
                    "name": "plc",
                    "kind": "bin"
                }
            },
            "program": "target/debug/plc",
            "args": [
                "build",
                "./tests/integration/data/empty_proj/conf/plc.json",
                "--debug"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "RUST_LOG": "rusty"
            },
            "terminal": "integrated",
            "initCommands":["settings set target.disable-aslr false"]
        },
        {
            "type": "codelldb",
            "request": "launch",
            "name": "Debug codelldb empty project",
            "cargo": {
                "args": [
                    "build",
                    "--bin=plc",
                    "--package=plc_driver"
                ],
                "filter": {
                    "name": "plc",
                    "kind": "bin"
                }
            },
            "program": "target/debug/plc",
            "args": [
                "build",
                "tests/integration/data/empty_proj/conf/plc.json"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "RUST_LOG": "rusty"
            },
            "terminal": "integrated"
        },
        {
            "type": "codelldb",
            "request": "launch",
            "name": "Debug codelldb standard_lib",
            "cargo": {
                "args": [
                    "build",
                    "--bin=plc",
                    "--package=plc_driver"
                ],
                "filter": {
                    "name": "plc",
                    "kind": "bin"
                }
            },
            "program": "target/debug/plc",
            "args": [
                "../stickle/source/*.st -c -i ../stickle/externals/stdlib_externals.st -i ../stickle/externals/omron_externals.st -l iec61131std -l libNX1P2 -l ws2_32 -l ntdll -l userenv -o ../stickle/compiled/lib_structured_text.o"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "RUST_LOG": "rusty"
            },
            "terminal": "integrated"
        },
        {
            "type": "codelldb",
            "request": "launch",
            "name": "Debug codelldb 'target/demo.st'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=plc",
                    "--package=plc_driver"
                ],
                "filter": {
                    "name": "plc",
                    "kind": "bin"
                }
            },
            "program": "target/debug/plc",
            "args": [
                "target/demo.st",
                "-g",
                "-c"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "RUST_LOG": "rusty"
            },
            "terminal": "integrated"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug source 'target/demo.st'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=plc",
                    "--package=plc_driver"
                ],
                "filter": {
                    "name": "plc",
                    "kind": "bin"
                }
            },
            "args": [
                "-j=1",
                "target/demo.st",
                "tests/lit/util/printf.pli"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "RUST_LOG": "rusty"
            },
            "terminal": "integrated"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit test 'demo'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--lib",
                    "--package=plc_driver"
                ],
                "filter": {
                    "name": "plc",
                    "kind": "lib"
                }
            },
            "args": [
                "demo"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "RUST_LOG": "rusty"
            },
            "terminal": "integrated"
        },
        {
            "type": "codelldb",
            "request": "launch",
            "name": "Debug st application demo",
            "cwd": "${workspaceFolder}",
            "program": "target/demo",
            "terminal": "integrated"
        }
    ]
}
